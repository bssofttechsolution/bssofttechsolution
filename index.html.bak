    <!-- ===== SERVICES SECTION ===== -->
    <section id="services" class="services-section">
      <div class="container">
        <div class="section-header" data-aos="fade-up">
          <span class="section-tag">What We Offer</span>
          <h2 class="section-title">50+ Premium IT Services <span class="gradient-text">Worldwide</span></h2>
          <p class="section-desc">From concept to deployment — we cover every aspect of digital technology to help your business thrive in the modern world.</p>
        </div>

        <!-- Service Filter Tabs -->
        <div class="service-tabs" data-aos="fade-up">
          <button class="stab active" data-filter="all">All Services</button>
          <button class="stab" data-filter="development">Development</button>
          <button class="stab" data-filter="cloud-ai">Cloud & AI</button>
          <button class="stab" data-filter="digital">Digital & Design</button>
          <button class="stab" data-filter="enterprise">Enterprise</button>
        </div>

        <div class="services-grid">
          <!-- Development -->
          <div class="service-card" data-category="development" data-aos="fade-up" data-aos-delay="0">
            <div class="sc-icon sc-blue"><i class="fas fa-globe"></i></div>
            <h3>Web Design & Development</h3>
            <p>Stunning, high-performance websites and web applications built with the latest technologies — React, Angular, Vue, Next.js & more.</p>
            <ul class="sc-tags"><li>React.js</li><li>Next.js</li><li>Vue.js</li><li>PHP/Laravel</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="development" data-aos="fade-up" data-aos-delay="50">
            <div class="sc-icon sc-purple"><i class="fas fa-mobile-alt"></i></div>
            <h3>Mobile App Development</h3>
            <p>Native and cross-platform mobile apps for iOS and Android. Flutter, React Native, Swift, and Kotlin — we build it all.</p>
            <ul class="sc-tags"><li>Flutter</li><li>React Native</li><li>Swift</li><li>Kotlin</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="development" data-aos="fade-up" data-aos-delay="100">
            <div class="sc-icon sc-green"><i class="fas fa-code"></i></div>
            <h3>Custom Software Development</h3>
            <p>Tailor-made software solutions that perfectly align with your business processes and enable scalable growth.</p>
            <ul class="sc-tags"><li>Python</li><li>Java</li><li>.NET</li><li>Node.js</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="development" data-aos="fade-up" data-aos-delay="150">
            <div class="sc-icon sc-orange"><i class="fas fa-shopping-cart"></i></div>
            <h3>E-Commerce Solutions</h3>
            <p>Powerful online stores with seamless checkout, payment gateway integration, and inventory management systems.</p>
            <ul class="sc-tags"><li>Shopify</li><li>WooCommerce</li><li>Magento</li><li>Custom</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <!-- Cloud & AI -->
          <div class="service-card" data-category="cloud-ai" data-aos="fade-up" data-aos-delay="0">
            <div class="sc-icon sc-cyan"><i class="fas fa-cloud"></i></div>
            <h3>Cloud Computing & Migration</h3>
            <p>Seamless cloud migration and management on AWS, Azure, and Google Cloud. Scalable, secure, and cost-effective infrastructure.</p>
            <ul class="sc-tags"><li>AWS</li><li>Azure</li><li>GCP</li><li>Docker/K8s</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="cloud-ai" data-aos="fade-up" data-aos-delay="50">
            <div class="sc-icon sc-blue"><i class="fas fa-brain"></i></div>
            <h3>Artificial Intelligence & ML</h3>
            <p>Intelligent AI solutions — chatbots, predictive analytics, computer vision, NLP, and custom ML model development.</p>
            <ul class="sc-tags"><li>TensorFlow</li><li>PyTorch</li><li>OpenAI</li><li>LangChain</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="cloud-ai" data-aos="fade-up" data-aos-delay="100">
            <div class="sc-icon sc-purple"><i class="fas fa-database"></i></div>
            <h3>Data Analytics & Business Intelligence</h3>
            <p>Transform raw data into actionable insights with advanced analytics dashboards, data warehousing, and reporting tools.</p>
            <ul class="sc-tags"><li>Power BI</li><li>Tableau</li><li>BigQuery</li><li>Spark</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="cloud-ai" data-aos="fade-up" data-aos-delay="150">
            <div class="sc-icon sc-green"><i class="fas fa-server"></i></div>
            <h3>DevOps & CI/CD Pipelines</h3>
            <p>Accelerate delivery with automated deployment pipelines, container orchestration, and robust monitoring solutions.</p>
            <ul class="sc-tags"><li>Jenkins</li><li>GitHub Actions</li><li>Terraform</li><li>Kubernetes</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <!-- Digital & Design -->
          <div class="service-card" data-category="digital" data-aos="fade-up" data-aos-delay="0">
            <div class="sc-icon sc-orange"><i class="fas fa-chart-line"></i></div>
            <h3>Digital Marketing & SEO</h3>
            <p>Dominate search rankings and generate leads with data-driven SEO, PPC, social media marketing, and content strategies.</p>
            <ul class="sc-tags"><li>SEO</li><li>Google Ads</li><li>Social Media</li><li>Email Mktg</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="digital" data-aos="fade-up" data-aos-delay="50">
            <div class="sc-icon sc-cyan"><i class="fas fa-paint-brush"></i></div>
            <h3>UI/UX Design</h3>
            <p>User-first design experiences that convert visitors into customers. Wireframes, prototypes, and pixel-perfect interfaces.</p>
            <ul class="sc-tags"><li>Figma</li><li>Adobe XD</li><li>Sketch</li><li>Prototyping</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="digital" data-aos="fade-up" data-aos-delay="100">
            <div class="sc-icon sc-blue"><i class="fas fa-shield-alt"></i></div>
            <h3>Cybersecurity Solutions</h3>
            <p>Protect your digital assets with penetration testing, vulnerability assessments, VAPT, and 24/7 security monitoring.</p>
            <ul class="sc-tags"><li>VAPT</li><li>SOC</li><li>ISO 27001</li><li>GDPR</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <div class="service-card" data-category="digital" data-aos="fade-up" data-aos-delay="150">
            <div class="sc-icon sc-purple"><i class="fas fa-gamepad"></i></div>
            <h3>Game Development</h3>
            <p>Immersive 2D/3D games for mobile, web, and desktop platforms using Unity, Unreal Engine, and custom game engines.</p>
            <ul class="sc-tags"><li>Unity</li><li>Unreal</li><li>HTML5</li><li>AR/VR</li></ul>
            <a href="#contact" class="sc-link">Get Started <i class="fas fa-arrow-right"></i></a>
          </div>

          <!-- Enterprise -->
          <div class="service-card" data-category="enterprise" data-aos="fade-up" data-aos-delay="0">
            <div class="sc-icon sc-green"><i class="fas fa-cogs"></i></div>
            <h3>ERP & CRM Solutions</h3>
